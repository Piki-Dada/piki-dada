DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="900"
JWT_REFRESH_EXPIRES_IN="604800"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4001/auth/google/callback"
PORT=4001
CORS_ORIGIN="http://localhost:3000"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_SECRET_HASH=""
# SMTP -- required, app crashes on boot if missing.
# Using Brevo's free SMTP relay (300 emails/day, free forever): get SMTP_USER/SMTP_PASSWORD
# from Brevo dashboard > SMTP & API > SMTP.
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="Piki Dada <noreply@example.com>"
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# Web push (VAPID) — required, app crashes on boot if missing. Generate with:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@pikidada.app"
# Used once by `pnpm db:seed` to bootstrap the first admin account (self-registering as
# ADMIN through the public API is blocked by design). Leave unset to skip.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
# Error tracking — leave unset to skip (errors still get logged to stdout via Logger).
SENTRY_DSN=""
# AES-256-GCM key for app-level field encryption (currently just User.phone). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Free to generate, no vendor needed — but once set, never change it without first
# decrypting and re-encrypting existing data, or those rows become unreadable.
FIELD_ENCRYPTION_KEY=""
